Port 22
AddressFamily inet
ListenAddress 0.0.0.0
HostKey /etc/ssh/ssh_host_ed25519_key
SyslogFacility AUTH
LogLevel VERBOSE
PermitRootLogin no
PubkeyAuthentication yes
AuthorizedKeysFile .ssh/authorized_keys
MaxAuthTries 6
PasswordAuthentication no
PermitEmptyPasswords no
ChallengeResponseAuthentication no
UsePAM yes
AllowAgentForwarding no
AllowTcpForwarding no
IgnoreRhosts yes
HostbasedAuthentication no
GatewayPorts no
PermitUserEnvironment no
X11Forwarding no
PrintMotd no
PrintLastLog yes
TCPKeepAlive yes
UseDNS no
PermitTunnel no
AcceptEnv LANG LC_*

Subsystem       sftp    /usr/lib/openssh/sftp-server -f AUTHPRIV -l INFO -u 0027

# Solo AEAD ciphers — ordine ottimizzato per hw con AES-NI
Ciphers chacha20-poly1305@openssh.com,aes128-gcm@openssh.com,aes256-gcm@openssh.com

# Solo ETM MACs — già buono, aggiunto sha2-512 per completezza
MACs hmac-sha2-512-etm@openssh.com,hmac-sha2-256-etm@openssh.com

# Post-quantum ibridi prima, classici dopo — senza duplicati
KexAlgorithms mlkem768x25519-sha256,sntrup761x25519-sha512@openssh.com,curve25519-sha256,curve25519-sha256@libssh.org

# Con varianti certificate per ambienti CA
HostKeyAlgorithms ssh-ed25519-cert-v01@openssh.com,rsa-sha2-512-cert-v01@openssh.com,ssh-ed25519,rsa-sha2-512

RekeyLimit 1G 1h
AllowUsers john
